# LLM Configuration
LLM_DEFAULT_MODEL=llama3.2:1b
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TOP_K=40
LLM_TOP_P=0.95

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=120

# Custom / Winner Model Configuration
ENABLE_CUSTOM_MODEL=false
CUSTOM_CHECKPOINT=checkpoints/tiny_transformer_best.pt
CUSTOM_TOKENIZER=checkpoints/tokenizer.json

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1

# Authentication (multi-user)
JWT_SECRET=

# RAG Configuration
ENABLE_RAG=true
EMBEDDING_MODEL=nomic-embed-text
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.3
RAG_WEB_FALLBACK=true
ENABLE_HYBRID_RAG=true
ENABLE_RERANKING=true

# Tool Calling
ENABLE_TOOLS=true

# Persistent Memory
ENABLE_MEMORY=true

# Thinking / CoT Traces
ENABLE_THINKING=true

# Guardrails & Safety
ENABLE_GUARDRAILS=true
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60

# Agent Planning
ENABLE_AGENT=true

# Context Management
CONTEXT_MAX_TOKENS=4096

# AI Image Generation (requires GPU + diffusers)
AI_IMAGE_GEN=false

# MCP Server (optional)
MCP_SERVER_URL=

# Logging
LOG_LEVEL=INFO
