# LLM Configuration
LLM_DEFAULT_MODEL=qwen3.5:latest
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# Custom / Winner Model Configuration
ENABLE_CUSTOM_MODEL=false
CUSTOM_CHECKPOINT=checkpoints/tiny_transformer_best.pt
CUSTOM_TOKENIZER=checkpoints/tokenizer.json

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1

# Logging
LOG_LEVEL=INFO
